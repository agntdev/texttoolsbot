[
  {
    "name": "/count with text returns word count",
    "steps": [
      {
        "send": { "text": "/count hello world" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Word count: 2" } }
        ]
      }
    ]
  },
  {
    "name": "/count with no arguments shows usage",
    "steps": [
      {
        "send": { "text": "/count" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Usage: /count <text>" } }
        ]
      }
    ]
  }
]